<%- include('partials/header') %>

<main>
     <h1 id="main-heading"><%= title %></h1>

    <h2>Welcome to the CSE 340 Service Network!</h2>
    <p>Our mission is to promote service across the world by connecting volunteers with service opportunities in their community.</p>

    <div class="logo-section">
        <img class="main-logo" src="images/cse340-service-network.png" alt="CSE 340 Service Network Logo">
        <div class="logo-text">
          <% if (isLoggedIn) { %>
            <a href="/dashboard" class="button-primary">
              <i data-lucide="grid"></i>
              Go to Dashboard
            </a>
          <% } else { %>
            <a href="/login" class="button-primary">
              <i data-lucide="log-in"></i>
              Login Now
            </a>
          <% } %>
        </div>
    </div>

    <% if (isLoggedIn) { %>
        <!-- Dashboard link removed from here as it's now in the hero section -->
    <% } %>

</main>

<script src="/js/button.js" defer></script>
<%- include('partials/footer') %>